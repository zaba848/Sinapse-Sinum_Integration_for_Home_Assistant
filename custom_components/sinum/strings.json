{
  "title": "Sinapse",
  "config": {
    "step": {
      "user": {
        "title": "Connect to Sinum hub",
        "description": "Enter the IP address or hostname of your Sinum EH-01 hub and choose an authentication method.",
        "data": {
          "host": "IP address or hostname",
          "auth_mode": "Authentication method"
        },
        "data_description": {
          "auth_mode": "**API Token** (recommended) — more secure, no password stored. Create a token in the Sinum web UI under Settings → System → Integrations. **Password** — standard username + password login."
        }
      },
      "token": {
        "title": "Sinum API Token",
        "description": "Create an external integration token in the Sinum web UI (Settings → System → Integrations → External integration tokens → Add token) and paste it below.",
        "data": {
          "api_token": "API Token",
          "scan_interval": "Polling interval (seconds)"
        }
      },
      "password": {
        "title": "Sinum credentials",
        "description": "Enter your Sinum hub login credentials.",
        "data": {
          "username": "Username",
          "password": "Password",
          "scan_interval": "Polling interval (seconds)"
        }
      },
      "reauth_confirm": {
        "title": "Re-authenticate Sinum",
        "description": "Update your Sinum hub authentication credentials.",
        "data": {
          "api_token": "API Token",
          "username": "Username",
          "password": "Password"
        }
      },
      "reconfigure": {
        "title": "Reconfigure Sinum hub",
        "description": "Change the hub address or authentication method. All existing entities will be preserved.",
        "data": {
          "host": "IP address or hostname",
          "auth_mode": "Authentication method"
        },
        "data_description": {
          "auth_mode": "**API Token** (recommended) or **Password** authentication."
        }
      }
    },
    "error": {
      "cannot_connect": "Cannot connect to the hub. Check the IP address and network connectivity.",
      "invalid_auth": "Invalid token or credentials.",
      "invalid_host": "Invalid host. Provide only an IP address or hostname (without path).",
      "too_many_attempts": "Too many failed attempts. Please wait {minutes} minute(s) before trying again.",
      "unknown": "An unexpected error occurred."
    },
    "abort": {
      "already_configured": "This Sinum hub is already configured.",
      "reconfigure_successful": "Sinum hub reconfigured successfully."
    }
  },
  "options": {
    "step": {
      "init": {
        "title": "Sinum integration options",
        "data": {
          "scan_interval": "Polling interval (seconds)",
          "mqtt_enabled": "Enable MQTT real-time transport",
          "mqtt_topic_prefix": "MQTT topic prefix",
          "mqtt_scene_id": "MQTT bridge scene ID",
          "mqtt_client_id": "MQTT client ID (on hub)",
          "ws_enabled": "Enable WebSocket real-time transport",
          "ws_path": "WebSocket path"
        },
        "data_description": {
          "mqtt_enabled": "Requires the Lua bridge script on the hub and a working MQTT broker in Home Assistant.",
          "mqtt_topic_prefix": "Must match TOPIC_PREFIX in the uploaded mqtt_bridge.lua. Use a unique prefix per hub, e.g. sinum/tablica-wtp.",
          "mqtt_scene_id": "ID of the scene where the MQTT bridge Lua script will be uploaded. Create an empty Lua scene in the Sinum hub web UI first, then use the sinum.upload_mqtt_bridge service.",
          "mqtt_client_id": "MQTT client index (1-based) configured in the Sinum hub under Settings → System → Integrations → MQTT client → Client list. The broker address must be set to your Home Assistant IP in the hub web UI.",
          "ws_enabled": "Connect via WebSocket for instant state updates without polling. Requires hub firmware that supports /api/v1/ws.",
          "ws_path": "Hub WebSocket endpoint path (default: /api/v1/ws)."
        }
      }
    }
  },
