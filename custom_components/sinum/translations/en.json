{
  "config": {
    "step": {
      "user": {
        "title": "Connect to Sinum hub",
        "description": "Enter the IP address or hostname of your Sinum EH-01 hub and choose an authentication method.",
        "data": {
          "host": "IP address or hostname",
          "auth_mode": "Authentication method"
        },
        "data_description": {
          "auth_mode": "**API Token** (recommended) — more secure, no password stored. Create a token in the Sinum app. **Password** — standard username + password login."
        }
      },
      "token": {
        "title": "Sinum API Token",
        "description": "Create a static API token in the Sinum app (Settings → Integrations → API Tokens) and paste it below.",
